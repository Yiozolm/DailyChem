# OpenAI SDK credentials and endpoint configuration.
# Copy to `.env` for local development if your shell / runner loads env files.
# `chemwf llm ...` also auto-loads the nearest `.env` from the current directory upward.
# Never commit `.env`.

OPENAI_API_KEY=

# Optional: proxy, self-hosted gateway, or OpenAI-compatible endpoint.
# Leave empty to use the OpenAI SDK default endpoint.
OPENAI_BASE_URL=

# Optional project-level default model for Phase 9 LLM helpers.
CHEMWF_OPENAI_MODEL=gpt-5.4-mini

# Optional: use `chat-completions` for OpenAI-compatible gateways that do not implement
# the Responses API `/responses` endpoint.
CHEMWF_OPENAI_API_MODE=responses

# Optional: DeepSeek-compatible setup.
# DEEPSEEK_API_KEY=
# OPENAI_BASE_URL=https://api.deepseek.com
# CHEMWF_OPENAI_MODEL=deepseek-v4-pro
# CHEMWF_OPENAI_API_MODE=chat-completions
# CHEMWF_OPENAI_API_KEY_ENV=DEEPSEEK_API_KEY
# CHEMWF_OPENAI_REASONING_EFFORT=high
# CHEMWF_OPENAI_ENABLE_THINKING=true

# Optional: point the loader at a specific dotenv file from your shell.
# export CHEMWF_ENV_FILE=/absolute/path/to/.env
